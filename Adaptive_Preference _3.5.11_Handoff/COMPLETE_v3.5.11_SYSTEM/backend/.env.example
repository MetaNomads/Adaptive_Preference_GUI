# .env.example 

# ======================
# Authentication
# ======================

# JWT secret for signing tokens
ADAPTIVE_PREF_JWT_SECRET=CHANGE_ME_TO_RANDOM_STRING

# Flask session / CSRF secret
SECRET_KEY=CHANGE_ME_TO_RANDOM_STRING

# ======================
# Database
# ======================

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/adaptive_testing

# ============================================================================
# FLASK CONFIGURATION
# ============================================================================

FLASK_ENV=development
FLASK_APP=api.py

# ============================================================================
# CORS CONFIGURATION
# ============================================================================

# Allow requests from your frontend (adjust port if needed)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://localhost:8000

# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================

UPLOAD_FOLDER=backend/assets/stimuli

# ============================================================================
# RATE LIMITING (Optional but recommended)
# ============================================================================

SESSIONS_RATE=10 per minute
NEXT_RATE=120 per minute
CHOICE_RATE=240 per minute

# ============================================================================
# DEVELOPMENT FEATURES
# ============================================================================

# Enable development token issuance (set to 0 in production)
AUTH_DEV_ISSUE_TOKENS=1

# Disable governance checks for development
APP_ENFORCE_GOVERNANCE=0

