# Adaptive Preference Testing System - Environment Configuration

# ============================================================================
# DATABASE CONFIGURATION (REQUIRED)
# ============================================================================

# Your current PostgreSQL database
# Note: Format should include username and optionally password
# Format: postgresql://username:password@host/database
DATABASE_URL=postgresql://postgres@localhost/adaptive_testing

# Alternative if you need to specify a password:
# DATABASE_URL=postgresql://postgres:your_password@localhost/adaptive_testing

# Or use SQLite for simpler setup (no PostgreSQL needed):
# DATABASE_URL=sqlite:///adaptive_preference.db

# ============================================================================
# SECURITY (REQUIRED)
# ============================================================================

# JWT Secret for authentication
JWT_SECRET=CHANGE_THIS_IN_PRODUCTION_TO_RANDOM_STRING_12345

# Flask secret key (add this - it's required by the application)
SECRET_KEY=flask-secret-key-change-in-production-67890

# ============================================================================
# FLASK CONFIGURATION
# ============================================================================

FLASK_ENV=development
FLASK_APP=api.py

# ============================================================================
# CORS CONFIGURATION
# ============================================================================

# Allow requests from your frontend (adjust port if needed)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================

UPLOAD_FOLDER=./uploads

# ============================================================================
# RATE LIMITING (Optional but recommended)
# ============================================================================

SESSIONS_RATE=10 per minute
NEXT_RATE=120 per minute
CHOICE_RATE=240 per minute

# ============================================================================
# DEVELOPMENT FEATURES
# ============================================================================

# Enable development token issuance (set to 0 in production)
AUTH_DEV_ISSUE_TOKENS=1

# Disable governance checks for development
APP_ENFORCE_GOVERNANCE=0
